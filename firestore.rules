rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Products Collection: Public read and write for catalog sync
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Articles Collection: Public read and write for blog sync
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders Collection: Public write (customers creating orders) & read for admin
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Settings Document & Collection
    match /settings/{document=**} {
      allow read, write: if true;
    }

    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
